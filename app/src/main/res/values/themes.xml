<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Tema principal ──────────────────────────────────────────────────── -->
    <style name="Theme.HamburgueriaZ" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/red_primary</item>
        <item name="colorPrimaryVariant">@color/red_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/red_primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/background_page</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/red_dark</item>
    </style>

    <!-- ── Estilos Base  ──────────────────────────────────────────────────── -->
    <style name="TextStyle" />
    <style name="ButtonStyle" />
    <style name="CheckBoxStyle" />
    <style name="CardStyle" />

    <!-- ── Textos ───────────────────────────────────────────────────────────── -->

    <!-- Título de seção -->
    <style name="TextStyle.SectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Input "Informe o nome" -->
    <style name="TextStyle.FieldLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Asterisco obrigatório -->
    <style name="TextStyle.Required">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/red_primary</item>
    </style>

    <!-- Preço Hamburguer -->
    <style name="TextStyle.Price">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/red_primary</item>
    </style>

    <!-- Texto de corpo / resumo -->
    <style name="TextStyle.Body">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Rótulo "RESUMO DO PEDIDO" -->
    <style name="TextStyle.SectionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <!-- Contador de quantidade -->
    <style name="TextStyle.Counter">
        <item name="android:layout_width">64dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:background">@color/background_page</item>
    </style>

    <!-- CheckBox de adicional -->
    <style name="CheckBoxStyle.Adicional">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:padding">6dp</item>
    </style>

    <!-- ── Botões ────────────────────────────────────────────────────────────── -->

    <!-- Botão Fazer Pedido -->
    <style name="ButtonStyle.Primary">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:backgroundTint">@color/red_primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Botões de quantidade -->
    <style name="ButtonStyle.Counter">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">22sp</item>
        <item name="android:backgroundTint">@color/red_primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Estilo padrão de texto  -->
    <style name="EstiloTexto">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ── Cards / Containers ────────────────────────────────────────────────── -->

    <!-- Card genérico  -->
    <style name="CardStyle.Default">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@color/surface_card</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:elevation">2dp</item>
    </style>

</resources>